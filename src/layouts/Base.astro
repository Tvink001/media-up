---
import '../styles/global.css';
import { Font } from 'astro:assets';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Media UP - Performance That Drives Real Growth',
  description =
    'Performance marketing agency that builds growth systems through traffic, analytics, and scalable advertising campaigns across global markets.',
} = Astro.props;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#05070e" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Media UP" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />

    <Font cssVariable="--font-manrope" preload={[{ weight: 800 }]} />
    <Font cssVariable="--font-inter" preload={[{ weight: 400 }]} />

    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
