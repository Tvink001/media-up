---
import Panel from './Panel.astro';

interface Props {
  titleId: string;
  title: string;
  para: string;
  points: string[];
}
const { titleId, title, para, points } = Astro.props;
const gradId = `cpu-${titleId}`;
---

<section class="checkpanel" aria-labelledby={titleId}>
  <Panel variant="gold">
    <div class="checkpanel__body">
      <div class="checkpanel__head">
        <h2 id={titleId} class="checkpanel__title">{title}</h2>
        <p class="checkpanel__para">{para}</p>
      </div>
      <ul class="checkpanel__list">
        <svg class="checkpanel__grad" aria-hidden="true" focusable="false">
          <defs>
            <linearGradient id={gradId} x1="2" y1="2" x2="23" y2="2.4" gradientUnits="userSpaceOnUse">
              <stop stop-color="#636eb7"></stop>
              <stop offset="0.32" stop-color="#fdfdfe"></stop>
              <stop offset="0.48" stop-color="#afbcd8"></stop>
              <stop offset="0.75" stop-color="#bac7dd"></stop>
              <stop offset="0.88" stop-color="#616db6"></stop>
            </linearGradient>
          </defs>
        </svg>
        {
          points.map((p) => (
            <li class="checkpanel__row">
              <svg
                class="checkpanel__icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke={`url(#${gradId})`}
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="4" y="4" width="16" height="16" rx="2" />
                <rect x="9" y="9" width="6" height="6" />
                <path d="M15 2v2M15 20v2M2 15h2M2 9h2M20 15h2M20 9h2M9 2v2M9 20v2" />
              </svg>
              <span class="checkpanel__text">{p}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </Panel>
</section>

<style>
  .checkpanel {
    padding: var(--section-y) var(--gutter);
  }

  .checkpanel__body {
    display: flex;
    flex-direction: column;
    gap: 22px;
    padding: 44px 24px;
  }

  .checkpanel__head {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
    text-align: center;
  }

  .checkpanel__title {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 27px;
    letter-spacing: -0.88px;
    line-height: 1.15;
    color: var(--text);
  }

  .checkpanel__para {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 15.5px;
    line-height: 24px;
    color: var(--muted);
  }

  .checkpanel__list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .checkpanel__grad {
    position: absolute;
    width: 0;
    height: 0;
  }

  .checkpanel__row {
    display: flex;
    gap: 14px;
    align-items: center;
    border: 2px solid transparent;
    border-radius: var(--r-card);
    background:
      var(--chip-grad) padding-box,
      var(--card-stroke) border-box;
    padding: 18px 22px;
    box-shadow: var(--chip-shadow), inset 0 4px 4px rgba(0, 0, 0, 0.25);
  }

  .checkpanel__icon {
    flex: none;
    width: 28px;
    height: 28px;
  }

  .checkpanel__text {
    flex: 1;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 15px;
    line-height: 18px;
    color: var(--text);
  }

  @media (min-width: 1024px) {
    .checkpanel {
      padding: 80px 0;
    }

    .checkpanel :global(.panel) {
      width: min(1192px, 100% - 48px);
      margin-inline: auto;
    }

    .checkpanel__body {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 40px;
      padding: 82px 62px 87px;
    }

    .checkpanel__head {
      flex: 1;
      align-items: flex-start;
      text-align: left;
      gap: 15px;
    }

    .checkpanel__title {
      font-size: 35px;
      letter-spacing: -1.14px;
      line-height: 51px;
    }

    .checkpanel__para {
      font-size: 16.3px;
      line-height: 28.56px;
      max-width: 580px;
    }

    .checkpanel__list {
      width: 400px;
      flex: none;
      gap: 15px;
    }

    .checkpanel__row {
      gap: 16px;
      padding: 20px 26px;
    }

    .checkpanel__icon {
      width: 30px;
      height: 30px;
    }

    .checkpanel__text {
      font-size: 15.5px;
      line-height: 17.38px;
    }
  }
</style>
