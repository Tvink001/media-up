---
import { Picture } from 'astro:assets';
import growth from '../assets/images/growth-reflection.png';
import footerBg from '../assets/images/footer-bg.webp';
import logo from '../assets/images/logo-lockup.png';
---

<footer class="footer">
  <div class="footer__growth">
    <Picture
      src={growth}
      formats={['avif', 'webp']}
      width={1192}
      height={372}
      widths={[720, 1192]}
      sizes="(min-width: 1024px) 1192px, 100vw"
      alt="Growth"
      loading="lazy"
    />
  </div>
  <div class="footer__bar">
    <img
      class="footer__bar-bg"
      src={footerBg.src}
      width={footerBg.width}
      height={footerBg.height}
      alt=""
      aria-hidden="true"
      loading="lazy"
      decoding="async"
    />
    <div class="footer__bar-inner">
      <a href="#top" class="footer__logo" aria-label="Media UP - back to top">
        <img src={logo.src} width="207" height="36" alt="Media UP" />
      </a>
      <a href="#contact" class="btn-outline btn-outline--footer">Book a Consultation</a>
      <div class="footer__divider" aria-hidden="true"></div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg);
    display: flex;
    flex-direction: column;
    gap: 28px;
    align-items: center;
    padding: 24px var(--gutter) 44px;
  }

  .footer__growth {
    width: 100%;
    line-height: 0;
  }

  .footer__growth :global(img) {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .footer__bar {
    width: 100%;
    position: relative;
    border-radius: var(--r-card);
    overflow: hidden;
    background: var(--card);
    border: 1px solid var(--hairline-06);
  }

  .footer__bar-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  .footer__bar-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 32px 24px;
  }

  .footer__logo {
    display: none;
  }

  .btn-outline--footer {
    width: 220px;
    height: 50px;
    border-radius: var(--r-btn);
    font-size: 16px;
  }

  .footer__divider {
    width: 240px;
    height: 3px;
    border-radius: 2px;
    background: var(--chrome);
  }

  @media (min-width: 1024px) {
    .footer {
      padding: 112px var(--dt-gutter) 60px;
      gap: 80px;
    }

    .footer__growth,
    .footer__bar {
      max-width: 1192px;
      margin-inline: auto;
    }

    .footer__bar {
      height: 121px;
    }

    .footer__bar-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      width: min(987px, 100% - 96px);
      margin-inline: auto;
      height: 100%;
      gap: 0;
      padding: 0;
    }

    .footer__logo {
      display: inline-flex;
      align-items: center;
    }

    .footer__logo img {
      width: 207px;
      height: 36px;
      object-fit: contain;
    }

    .btn-outline--footer {
      width: 200px;
      height: 50px;
      font-size: 16.8px;
      flex: none;
    }

    .footer__divider {
      display: none;
    }
  }
</style>
