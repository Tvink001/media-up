---
import growth from '../assets/images/growth-reflection.webp';
import logo from '../assets/images/logo-lockup.png';
---

<footer class="footer">
  <span class="orb footer__orb-a" aria-hidden="true"></span>
  <span class="orb footer__orb-b" aria-hidden="true"></span>
  <div class="footer__growth">
    <img
      src={growth.src}
      width={growth.width}
      height={growth.height}
      alt="Growth"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="footer__bar">
    <div class="footer__bar-inner">
      <a href="#top" class="footer__logo" aria-label="Media UP - back to top">
        <img src={logo.src} width="207" height="36" alt="Media UP" />
      </a>
      <a href="#contact" class="btn-outline btn-outline--footer">Book a Consultation</a>
      <div class="footer__divider" aria-hidden="true"></div>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    overflow: hidden;
    background: var(--bg);
    display: flex;
    flex-direction: column;
    gap: 28px;
    align-items: center;
    padding: 24px var(--gutter) 44px;
  }

  .footer__orb-a {
    top: -80px;
    left: -300px;
  }

  .footer__orb-b {
    top: -120px;
    right: -300px;
  }

  .footer__growth {
    position: relative;
    z-index: 1;
    width: 100%;
    line-height: 0;
  }

  .footer__growth :global(img) {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .footer__bar {
    width: 100%;
    position: relative;
    z-index: 1;
    border-radius: 20px;
    overflow: hidden;
    border: 2px solid transparent;
    background:
      var(--panel-grad) padding-box,
      var(--card-stroke) border-box;
  }

  .footer__bar-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 32px 24px;
  }

  .footer__logo {
    display: none;
  }

  .btn-outline--footer {
    width: 220px;
    height: 50px;
    border-radius: var(--r-btn);
    font-size: 16px;
  }

  .footer__divider {
    width: 240px;
    height: 3px;
    border-radius: 2px;
    background: var(--chrome);
  }

  @media (min-width: 1024px) {
    .footer {
      padding: 112px var(--dt-gutter) 60px;
      gap: 80px;
    }

    .footer__growth,
    .footer__bar {
      max-width: 1192px;
      margin-inline: auto;
    }

    .footer__bar {
      height: 121px;
    }

    .footer__bar-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      width: min(987px, 100% - 96px);
      margin-inline: auto;
      height: 100%;
      gap: 0;
      padding: 0;
    }

    .footer__logo {
      display: inline-flex;
      align-items: center;
    }

    .footer__logo img {
      width: 207px;
      height: 36px;
      object-fit: contain;
    }

    .btn-outline--footer {
      width: 200px;
      height: 50px;
      font-size: 16.8px;
      flex: none;
    }

    .footer__divider {
      display: none;
    }
  }
</style>
