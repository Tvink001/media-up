---
// The hero art-head is a looping, muted video that sits in the exact box the
// static art-head used to occupy (the old 1024x1156 graphic's aspect ratio).
// Safari receives the HEVC (.mov) and every other browser the WEBM. The clip
// carries a dark backing, so a radial mask feathers its edges into the page the
// way the old transparent PNG did, and a poster frame paints instantly so the
// first render isn't blocked by the video download.
---

<section class="hero" aria-label="Introduction">
  <div class="hero__glow" aria-hidden="true"></div>
  <div class="hero__content">
    <div class="hero__figure" aria-hidden="true">
      <video
        class="hero__video"
        autoplay
        loop
        muted
        playsinline
        preload="metadata"
        poster="/hero/head-poster.webp"
      >
        <source src="/hero/head.mp4" type='video/mp4; codecs="hvc1"' />
        <source src="/hero/head.webm" type="video/webm" />
      </video>
    </div>
    <div class="hero__text">
      <h1 class="hero__title">Performance That Drives Real Growth</h1>
      <p class="hero__sub">
        Performance <span>agency that builds growth systems</span> through traffic,analytics, and
        scalable advertising campaigns.
      </p>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 104px var(--gutter) 36px;
  }

  .hero__glow {
    position: absolute;
    top: -200px;
    right: -200px;
    width: 520px;
    height: 520px;
    border-radius: 260px;
    -webkit-filter: blur(45px);
    filter: blur(45px);
    background: radial-gradient(circle at center, var(--glow-core) 0%, rgba(30, 65, 170, 0) 68%);
  }

  .hero__content {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }

  /* The figure reproduces the on-screen box the static art-head filled: same
     280px width and the old graphic's 1024:1156 aspect. The video is absolutely
     positioned so its intrinsic (portrait) height can't stretch the box, and
     cover-fitted so the head lands at yesterday's size and place. */
  .hero__figure {
    position: relative;
    width: 280px;
    aspect-ratio: 1024 / 1156;
    overflow: hidden;
    line-height: 0;
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 58%;
    -webkit-mask-image: radial-gradient(ellipse 72% 60% at 50% 45%, #000 52%, transparent 84%);
    mask-image: radial-gradient(ellipse 72% 60% at 50% 45%, #000 52%, transparent 84%);
  }

  .hero__title {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 40px;
    letter-spacing: -1px;
    line-height: 1.05;
    color: var(--text);
    text-align: center;
    word-break: break-word;
  }

  .hero__sub {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 17px;
    line-height: 29px;
    color: var(--muted);
    text-align: center;
  }

  .hero__sub span {
    color: var(--text);
  }

  @media (min-width: 1024px) {
    .hero {
      padding: 0 0 40px;
      min-height: 720px;
      display: flex;
      align-items: flex-start;
    }

    .hero__content {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 40px;
      width: min(1192px, 100% - 48px);
      margin-inline: auto;
      padding-top: 104px;
    }

    .hero__text {
      order: 1;
      align-items: flex-start;
      text-align: left;
      gap: 24px;
      max-width: 585px;
    }

    .hero__figure {
      order: 2;
      flex: none;
      width: clamp(360px, 38vw, 560px);
    }

    .hero__title {
      font-size: clamp(56px, 6.25vw, 90px);
      letter-spacing: -1.92px;
      line-height: 0.98;
      text-align: left;
      word-break: normal;
      overflow-wrap: normal;
    }

    .hero__sub {
      font-size: 18.4px;
      line-height: 32.2px;
      text-align: left;
      max-width: 515px;
    }
  }
</style>
