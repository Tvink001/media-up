---
// The hero art-head is a looping, muted video. Safari receives the HEVC (.mov)
// and every other browser the WEBM - the browser picks the first <source> whose
// codec it can decode. A poster frame paints instantly so the first render isn't
// blocked by the video download.
---

<section class="hero" aria-label="Introduction">
  <div class="hero__glow" aria-hidden="true"></div>
  <div class="hero__content">
    <div class="hero__figure" aria-hidden="true">
      <video
        class="hero__video"
        autoplay
        loop
        muted
        playsinline
        preload="metadata"
        poster="/hero/head-poster.webp"
      >
        <source src="/hero/head.mp4" type='video/mp4; codecs="hvc1"' />
        <source src="/hero/head.webm" type="video/webm" />
      </video>
    </div>
    <div class="hero__text">
      <h1 class="hero__title">Performance That Drives Real Growth</h1>
      <p class="hero__sub">
        Performance <span>agency that builds growth systems</span> through traffic,analytics, and
        scalable advertising campaigns.
      </p>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 104px var(--gutter) 36px;
  }

  .hero__glow {
    position: absolute;
    top: -200px;
    right: -200px;
    width: 520px;
    height: 520px;
    border-radius: 260px;
    -webkit-filter: blur(45px);
    filter: blur(45px);
    background: radial-gradient(circle at center, var(--glow-core) 0%, rgba(30, 65, 170, 0) 68%);
  }

  .hero__content {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }

  .hero__figure {
    width: 250px;
    aspect-ratio: 1 / 1.16;
    line-height: 0;
  }

  /* Fit the portrait clip to the head and feather the dark edges into the page. */
  .hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 42%;
    -webkit-mask-image: radial-gradient(ellipse 76% 72% at 50% 44%, #000 64%, transparent 94%);
    mask-image: radial-gradient(ellipse 76% 72% at 50% 44%, #000 64%, transparent 94%);
  }

  .hero__title {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 40px;
    letter-spacing: -1px;
    line-height: 1.05;
    color: var(--text);
    text-align: center;
    word-break: break-word;
  }

  .hero__sub {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 17px;
    line-height: 29px;
    color: var(--muted);
    text-align: center;
  }

  .hero__sub span {
    color: var(--text);
  }

  @media (min-width: 1024px) {
    .hero {
      padding: 0 0 40px;
      min-height: 620px;
      display: flex;
      align-items: flex-start;
    }

    .hero__content {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 40px;
      width: min(1192px, 100% - 48px);
      margin-inline: auto;
      padding-top: 116px;
    }

    .hero__text {
      order: 1;
      align-items: flex-start;
      text-align: left;
      gap: 24px;
      max-width: 585px;
    }

    .hero__figure {
      order: 2;
      flex: none;
      width: clamp(320px, 32vw, 430px);
    }

    .hero__title {
      font-size: clamp(56px, 6.25vw, 90px);
      letter-spacing: -1.92px;
      line-height: 0.98;
      text-align: left;
      word-break: normal;
      overflow-wrap: normal;
    }

    .hero__sub {
      font-size: 18.4px;
      line-height: 32.2px;
      text-align: left;
      max-width: 515px;
    }
  }
</style>
