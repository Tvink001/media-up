---
import { Picture } from 'astro:assets';
import hero from '../assets/images/hero-graphic.png';
---

<section class="hero" aria-label="Introduction">
  <span class="orb hero__orb-head" aria-hidden="true"></span>
  <span class="orb hero__orb-left" aria-hidden="true"></span>
  <span class="hero__oval" aria-hidden="true"></span>
  <div class="hero__content">
    <div class="hero__figure">
      <Picture
        src={hero}
        formats={['avif', 'webp']}
        width={676}
        height={764}
        widths={[280, 560, 676]}
        sizes="(min-width: 1024px) 560px, 280px"
        alt=""
        priority
      />
    </div>
    <div class="hero__text">
      <h1 class="hero__title">Performance That Drives Real Growth</h1>
      <p class="hero__sub">
        Performance <span>agency that builds growth systems</span> through traffic,analytics, and
        scalable advertising campaigns.
      </p>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 104px var(--gutter) 36px;
  }

  .hero__orb-head {
    width: 661px;
    height: 661px;
    right: -181px;
    top: -216px;
  }

  .hero__orb-left {
    width: 661px;
    height: 661px;
    left: -344px;
    bottom: 74px;
  }

  .hero__oval {
    position: absolute;
    z-index: 0;
    pointer-events: none;
    width: 210px;
    height: 280px;
    left: 547.193px;
    bottom: 245px;
    border-radius: 140px;
    background: radial-gradient(
      70.71% 70.71% at 50% 50%,
      rgba(62, 114, 236, 0.12) 0%,
      rgba(62, 114, 236, 0) 70%
    );
    -webkit-filter: blur(45px);
    filter: blur(45px);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }

  .hero__figure {
    line-height: 0;
  }

  .hero__figure :global(img) {
    width: 280px;
    height: auto;
  }

  .hero__title {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 40px;
    letter-spacing: -1px;
    line-height: 1.05;
    color: var(--text);
    text-align: center;
    word-break: break-word;
  }

  .hero__sub {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 17px;
    line-height: 29px;
    color: var(--muted);
    text-align: center;
  }

  .hero__sub span {
    color: var(--text);
  }

  @media (min-width: 1024px) {
    .hero {
      padding: 0 0 40px;
      min-height: 720px;
      display: flex;
      align-items: flex-start;
    }

    .hero__content {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 40px;
      width: min(1192px, 100% - 48px);
      margin-inline: auto;
      padding-top: 104px;
    }

    .hero__text {
      order: 1;
      align-items: flex-start;
      text-align: left;
      gap: 24px;
      max-width: 585px;
    }

    .hero__figure {
      order: 2;
      flex: none;
      transform: translateX(40px);
    }

    .hero__figure :global(img) {
      width: min(clamp(340px, 35vw, 500px), calc((100vh - 174px) * 0.884));
      height: auto;
    }

    .hero__title {
      font-size: clamp(56px, 6.25vw, 90px);
      letter-spacing: -1.92px;
      line-height: 0.98;
      text-align: left;
      word-break: normal;
      overflow-wrap: normal;
    }

    .hero__sub {
      font-size: 18.4px;
      line-height: 32.2px;
      text-align: left;
      max-width: 515px;
    }
  }
</style>
