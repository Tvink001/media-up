---
import Panel from './Panel.astro';

const stats = [
  { value: '28', label: 'Ad Impressions / Month', sub: 'Across all traffic sources' },
  { value: '310%', label: 'Average ROI', sub: 'Verified by partners' },
  { value: '16', label: 'Global GEOs', sub: 'Tier-1 & emerging markets' },
];
---

<section class="stats" aria-label="Key results">
  <Panel variant="stats">
    <ul class="stats__list">
      {
        stats.map((s) => (
          <li class="stats__item">
            <span class="stats__value chrome">{s.value}</span>
            <span class="stats__label">{s.label}</span>
            <span class="stats__sub">{s.sub}</span>
          </li>
        ))
      }
    </ul>
  </Panel>
</section>

<style>
  .stats {
    padding: 8px var(--gutter) var(--section-y);
  }

  .stats__list {
    display: flex;
    flex-direction: column;
    padding: 16px 24px;
  }

  .stats__item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    align-items: center;
    text-align: center;
    padding: 22px 0;
  }

  .stats__item:not(:last-child) {
    border-bottom: 1px solid var(--hairline-05);
  }

  .stats__value {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 40px;
    letter-spacing: -1.6px;
    line-height: 44px;
  }

  .stats__label {
    padding-top: 5px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 13.1px;
    line-height: 21.65px;
    color: var(--muted);
  }

  .stats__sub {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 11.5px;
    line-height: 19px;
    color: var(--dim);
  }

  @media (min-width: 1024px) {
    .stats {
      padding: 52px 0;
    }

    .stats :global(.panel) {
      width: min(1192px, 100% - 48px);
      margin-inline: auto;
    }

    .stats__list {
      flex-direction: row;
      padding: 58px 48px;
    }

    .stats__item {
      flex: 1;
      padding: 8px 29px;
    }

    .stats__item:not(:last-child) {
      border-bottom: none;
      border-right: 1px solid var(--hairline);
    }
  }
</style>
