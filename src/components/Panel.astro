---
interface Props {
  variant?: 'stats' | 'gold';
  class?: string;
}
const { variant = 'gold', class: cls } = Astro.props;
---

<div class:list={['panel', `panel--${variant}`, cls]}>
  <div class="panel__inner">
    <slot />
  </div>
</div>

<style>
  .panel {
    position: relative;
    border-radius: var(--r-panel);
    overflow: hidden;
    background: var(--panel-grad);
    border: 2px solid var(--panel-border);
  }

  .panel__inner {
    position: relative;
  }
</style>
