---
import { Image } from 'astro:assets';
import { channels } from '../data/content';
import propellerads from '../assets/images/chan-propellerads.png';
import googleads from '../assets/images/chan-googleads.png';
import applesearchads from '../assets/images/chan-applesearchads.png';
import metaads from '../assets/images/chan-metaads.png';
import tiktokads from '../assets/images/chan-tiktokads.png';
import nativeads from '../assets/images/chan-nativeads.png';
import pushnotifications from '../assets/images/chan-pushnotifications.png';
import poptraffic from '../assets/images/chan-poptraffic.png';

const icons: Record<string, ImageMetadata> = {
  propellerads,
  googleads,
  applesearchads,
  metaads,
  tiktokads,
  nativeads,
  pushnotifications,
  poptraffic,
};
---

<section id="channels" class="channels" aria-labelledby="channels-title">
  <div class="channels__wrap">
    <header class="channels__head">
      <h2 id="channels-title" class="channels__title chrome">Every Major Channel</h2>
      <p class="channels__sub">
        Full-stack traffic expertise across paid, native, push and programmatic channels worldwide.
      </p>
    </header>
    <ul class="channels__grid">
      {
        channels.map((c) => (
          <li class="channel">
            <span class="channel__tile" aria-hidden="true">
              <Image src={icons[c.icon]} width={112} height={63} alt="" loading="lazy" />
            </span>
            <div class="channel__text">
              <h3 class="channel__name">{c.name}</h3>
              <p class="channel__sub">{c.sub}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .channels {
    padding: var(--section-y) var(--gutter);
    scroll-margin-top: 16px;
  }

  .channels__wrap {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .channels__head {
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: center;
    text-align: center;
  }

  .channels__title {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 30px;
    letter-spacing: -0.9px;
    line-height: 1.15;
  }

  .channels__sub {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 16px;
    line-height: 26px;
    color: var(--muted);
  }

  .channels__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 14px;
  }

  .channel {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    background: var(--card-grad);
    border: 2px solid var(--card-border);
    border-radius: 30px;
    padding: 40px;
  }

  .channel__tile {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    overflow: hidden;
  }

  .channel__tile :global(img) {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .channel__text {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .channel__name {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 20px;
    line-height: 1.2;
    color: var(--text);
  }

  .channel__sub {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 15px;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.5);
  }

  @media (min-width: 1024px) {
    .channels {
      padding: 80px 0;
      scroll-margin-top: 24px;
    }

    .channels__wrap {
      width: min(1192px, 100% - 48px);
      margin-inline: auto;
      gap: 52px;
    }

    .channels__head {
      gap: 17px;
    }

    .channels__title {
      font-size: 44px;
      letter-spacing: -1.1px;
      line-height: 1.3;
    }

    .channels__sub {
      max-width: 520px;
      line-height: 28px;
    }

    .channels__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 20px;
    }

    .channel {
      padding: 50px 40px;
    }
  }
</style>
