---
import { partnerLogos } from '../data/partner-logos';
---

<section class="partners" aria-labelledby="partners-title">
  <header class="partners__head">
    <h2 id="partners-title" class="partners__title chrome">Working with the Best in Class</h2>
    <p class="partners__sub">
      We maintain direct relationships with premium ad networks, affiliate networks and CPA
      platforms worldwide.
    </p>
  </header>
  <div class="partners__viewport">
    <ul class="partners__track">
      {
        partnerLogos.map((l) => (
          <li class="chip">
            <span class="chip__mark" set:html={l.mark} />
            <span class="chip__text" set:html={l.text} />
          </li>
        ))
      }
      {
        partnerLogos.map((l) => (
          <li class="chip chip--dupe" aria-hidden="true">
            <span class="chip__mark" set:html={l.mark} />
            <span class="chip__text" set:html={l.text} />
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .partners {
    position: relative;
    padding: 36px 0;
    display: flex;
    flex-direction: column;
    gap: 32px;
    align-items: center;
    overflow: hidden;
  }

  .partners__head {
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: center;
    text-align: center;
    padding: 0 var(--gutter);
  }

  .partners__title {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 30px;
    letter-spacing: -0.9px;
    line-height: 1.15;
  }

  .partners__sub {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 16px;
    line-height: 26px;
    color: var(--muted);
  }

  .partners__viewport {
    width: 100%;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0%,
      #000 12%,
      #000 88%,
      transparent 100%
    );
    mask-image: linear-gradient(90deg, transparent 0%, #000 12%, #000 88%, transparent 100%);
  }

  .partners__track {
    display: flex;
    gap: 14px;
    width: max-content;
    animation: muMarquee 38s linear infinite;
  }

  .chip {
    display: flex;
    gap: 7px;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    border-radius: 32px;
    background:
      var(--card-grad) padding-box,
      var(--card-stroke) border-box;
    padding: 10px 18px;
    white-space: nowrap;
  }

  .chip__mark,
  .chip__text {
    display: inline-flex;
    align-items: center;
    line-height: 0;
    opacity: 0.84;
  }

  .chip__mark :global(svg),
  .chip__text :global(svg) {
    display: block;
  }

  @keyframes muMarquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (min-width: 1024px) {
    .partners {
      padding: 80px 0;
      gap: 48px;
    }

    .partners__head {
      max-width: 1192px;
      gap: 17px;
    }

    .partners__title {
      font-size: 44px;
      letter-spacing: -1.1px;
      line-height: 1.3;
    }

    .partners__sub {
      max-width: 520px;
      line-height: 28px;
    }

    .partners__viewport {
      width: min(1192px, 100% - 48px);
      overflow: visible;
      -webkit-mask-image: none;
      mask-image: none;
    }

    .partners__track {
      flex-wrap: wrap;
      justify-content: center;
      width: auto;
      gap: 16px;
      animation: none;
      transform: none;
    }

    .chip {
      padding: 10px 16px;
    }

    .chip--dupe {
      display: none;
    }
  }
</style>
