---
import logo from '../assets/images/logo-lockup.png';

const navLinks = [
  { href: '#niches', label: 'Verticals' },
  { href: '#channels', label: 'Traffic Sources' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="site-header">
  <a href="#top" class="site-header__logo" aria-label="Media UP - back to top">
    <img src={logo.src} width="150" height="26" alt="Media UP" />
  </a>

  <nav class="site-header__nav" aria-label="Primary">
    {navLinks.map((l) => <a href={l.href} class="chrome">{l.label}</a>)}
  </nav>

  <a href="#contact" class="btn-outline site-header__cta">Book a Consultation</a>

  <button
    type="button"
    class="burger"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="mobile-menu"
    data-menu-open
  >
    <span aria-hidden="true"></span>
    <span aria-hidden="true"></span>
    <span aria-hidden="true"></span>
  </button>
</header>

<style>
  .site-header {
    position: absolute;
    inset: 0 0 auto 0;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--gutter);
    z-index: 20;
  }

  .site-header__logo {
    display: inline-flex;
  }

  .site-header__logo img {
    width: 150px;
    height: 26px;
    object-fit: contain;
  }

  /* Desktop-only chrome; hidden on mobile where the hamburger takes over. */
  .site-header__nav,
  .site-header__cta {
    display: none;
  }

  .burger {
    width: 44px;
    height: 44px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    padding: 0;
  }

  .burger span {
    display: block;
    width: 24px;
    height: 2px;
    border-radius: 2px;
    background: var(--text);
    transition: background-color 0.2s ease;
  }

  @media (hover: hover) {
    .burger:hover span {
      background: #fff;
    }
  }

  @media (min-width: 1024px) {
    .site-header {
      height: 98px;
      padding: 22px var(--dt-gutter) 23px;
    }

    .site-header__logo img {
      width: 207px;
      height: 36px;
    }

    .site-header__nav {
      display: flex;
      gap: 30px;
      align-items: center;
    }

    .site-header__nav a {
      font-family: var(--font-body);
      font-weight: 700;
      font-size: 13.6px;
      letter-spacing: 0.14px;
      line-height: 22.44px;
      text-decoration: none;
    }

    .site-header__cta {
      display: flex;
      width: 200px;
      height: 50px;
      border-radius: var(--r-btn);
      font-size: 16.8px;
      flex: none;
    }

    .burger {
      display: none;
    }
  }
</style>
