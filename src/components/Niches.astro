---
import { Image } from 'astro:assets';
import { niches, type NicheIconKey } from '../data/content';
import education from '../assets/images/niche-education.png';
import finance from '../assets/images/niche-finance.png';
import nutra from '../assets/images/niche-nutra.png';
import saas from '../assets/images/niche-saas.png';
import crypto from '../assets/images/niche-crypto.png';
import igaming from '../assets/images/niche-igaming.png';
import mainstream from '../assets/images/niche-mainstream.png';
import leadgen from '../assets/images/niche-leadgen.png';

const icons: Record<NicheIconKey, ImageMetadata> = {
  education,
  finance,
  nutra,
  saas,
  crypto,
  igaming,
  mainstream,
  leadgen,
};
---

<section id="niches" class="niches" aria-labelledby="niches-title">
  <span class="orb orb--deep niches__orb-a" aria-hidden="true"></span>
  <span class="orb orb--deep niches__orb-b" aria-hidden="true"></span>
  <div class="niches__wrap">
    <header class="niches__head">
      <h2 id="niches-title" class="niches__title chrome">Niches We Dominate</h2>
      <p class="niches__sub">
        Deep expertise across the highest-performing verticals in performance marketing.
      </p>
    </header>
    <ul class="niches__grid">
      {
        niches.map((n) => (
          <li class="niche">
            <span class="niche__icon" aria-hidden="true">
              <Image src={icons[n.icon]} width={160} height={90} alt="" loading="lazy" />
            </span>
            <div class="niche__head">
              <h3 class="niche__title">{n.title}</h3>
              <p class="niche__desc">{n.desc}</p>
            </div>
            <span class="niche__tag">
              <span class="chrome">{n.tag}</span>
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .niches {
    position: relative;
    overflow: hidden;
    padding: var(--section-y) var(--gutter);
    scroll-margin-top: 16px;
  }

  .niches__orb-a {
    left: -110px;
    top: 7.34px;
  }

  .niches__orb-b {
    right: -167px;
    bottom: 20.15px;
  }

  .niches__wrap {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .niches__head {
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: center;
    text-align: center;
  }

  .niches__title {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 30px;
    letter-spacing: -0.9px;
    line-height: 1.15;
  }

  .niches__sub {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 16px;
    line-height: 26px;
    color: var(--muted);
  }

  .niches__grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .niche {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 20px;
    border: 2px solid transparent;
    border-radius: 22.7px;
    background:
      var(--card-grad) padding-box,
      var(--card-stroke) border-box;
    padding: 104px 30px 30px;
    overflow: hidden;
  }

  .niche__icon {
    position: absolute;
    top: 30px;
    right: 28px;
    width: 38px;
    height: 32px;
  }

  .niche__icon :global(img) {
    width: 100%;
    height: 100%;
    object-fit: fill;
  }

  .niche__head {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .niche__title {
    font-family: var(--font-head);
    font-weight: 800;
    font-size: 22px;
    line-height: 1.2;
    color: var(--text);
  }

  .niche__desc {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 12px;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.5);
  }

  .niche__tag {
    align-self: flex-start;
    display: flex;
    align-items: center;
    background: var(--icon-blue);
    border-radius: 7.568px;
    height: 28px;
    padding: 0 9px;
  }

  .niche__tag span {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.7px;
    text-transform: uppercase;
    line-height: 1;
  }

  @media (min-width: 1024px) {
    .niches {
      padding: 80px 0;
      scroll-margin-top: 24px;
    }

    .niches__wrap {
      width: min(1192px, 100% - 48px);
      margin-inline: auto;
      gap: 52px;
    }

    .niches__head {
      gap: 17px;
    }

    .niches__title {
      font-size: 44px;
      letter-spacing: -1.1px;
      line-height: 1.3;
    }

    .niches__sub {
      max-width: 520px;
      line-height: 28px;
    }

    .niches__grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 18px;
    }

    .niche {
      min-height: 288px;
      padding: 136px 30px 30px;
    }

    .niche__icon {
      top: 38px;
      right: 34px;
    }
  }
</style>
